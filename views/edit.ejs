<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Your Chat</title>
</head>
<body>
    <h3>Edit your chat <%=chat._id%></h3>
    <form action="">
    <p>This chat was sent from <b><%=chat.from%>to <%=chat.to%></b></p> 
    <br><br>
    <textarea name="msg" id="" rows="15" cols="20"><%=chat.msg%></textarea>
    <br><br> 
    <button>Edit</button> 
    
    </form>
</body>
</html>